{
  "manifest_version": 3,
  "name": "Web Annotator",
  "short_name": "Annotator",
  "version": "0.1.2",
  "description": "Webページのテキストにコメントを追加し、Markdown形式でエクスポートできる拡張機能",
  "homepage_url": "https://github.com/aaaa777/chrome-web-annotator",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Web Annotator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
